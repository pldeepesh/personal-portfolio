RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Force canonical host (www)
RewriteCond %{HTTP_HOST} !^www\.lakshmanadeepesh\.in$ [NC]
RewriteRule ^ https://www.lakshmanadeepesh.in%{REQUEST_URI} [L,R=301]

# Blog flat URLs: /blog/<slug>/ -> /blog/<slug>/index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^blog/([a-z0-9-]+)/?$ blog/$1/index.html [L]
